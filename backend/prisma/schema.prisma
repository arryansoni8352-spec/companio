// COMPANIO Database Schema
// Prisma ORM - SQLite for local dev, PostgreSQL for production
// Change provider to "postgresql" and update DATABASE_URL for production

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ============================================
// AUTH & USERS
// ============================================

model User {
  id            String   @id @default(uuid())
  email         String?  @unique
  phone         String?  @unique
  username      String   @unique
  passwordHash  String
  role          String   @default("user") // user, moderator, admin
  verified      Boolean  @default(false)
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?
  isDisabled    Boolean  @default(false)
  familyId    String?   // optional link to family
  family      Family?   @relation(fields: [familyId], references: [id])

  profile          Profile?
  sessions         Session[]
  devices          Device[]
  loginHistory     LoginHistory[]
  posts            Post[]
  stories          Story[]
  comments         Comment[]
  likes            Like[]
  saves            Save[]
  bookmarks        Bookmark[]
  sentMessages     Message[]          @relation("SentMessages")
  conversations    ConversationMember[]
  companionProfile CompanionProfile?
  matchesAsUser1   Match[]            @relation("MatchUser1")
  matchesAsUser2   Match[]            @relation("MatchUser2")
  ownedCommunities Community[]        @relation("CommunityOwner")
  communityMemberships CommunityMember[]
  createdEvents    Event[]
  eventRSVPs       EventRSVP[]
  reports          Report[]           @relation("Reporter")
  reportsAgainst   Report[]           @relation("ReportTarget")
  blocks           Block[]            @relation("Blocker")
  blockedBy        Block[]            @relation("Blocked")
  verifications    Verification[]
  trustScore       TrustScore?
  reviewsGiven     Review[]           @relation("Reviewer")
  reviewsReceived  Review[]           @relation("Reviewed")
  privacySettings  PrivacySetting[]
  notificationSettings NotificationSetting[]
  notifications    Notification[]
  pushTokens       PushToken[]
  followers        Follow[]           @relation("Following")
  following        Follow[]           @relation("Follower")
  bookingsMade     Booking[]          @relation("Booker")
  callParticipations CallParticipant[]
  aiConversations  AIConversation[]
  friendRequestsSent     FriendRequest[] @relation("FriendRequestsSent")
  friendRequestsReceived FriendRequest[] @relation("FriendRequestsReceived")
  familyMemberships      FamilyMember[]

  @@index([email])
  @@index([username])
  @@index([phone])
  @@index([isDisabled])
}

model Profile {
  id          String   @id @default(uuid())
  userId      String   @unique
  displayName String?
  bio         String?
  avatar      String?
  coverImage  String?
  website     String?
  location    String?
  interests   String?  // JSON array stored as string
  dateOfBirth DateTime?
  gender      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  token        String   @unique
  refreshToken String   @unique
  deviceInfo   String?
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  lastActive   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model Device {
  id         String   @id @default(uuid())
  userId     String
  name       String?
  type       String?  // mobile, desktop, tablet
  os         String?
  browser    String?
  trusted    Boolean  @default(false)
  lastUsed   DateTime @default(now())
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model LoginHistory {
  id        String   @id @default(uuid())
  userId    String
  ipAddress String?
  userAgent String?
  location  String?
  success   Boolean
  method    String?  // password, google, apple, 2fa
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============================================
// SOCIAL: FOLLOW SYSTEM
// ============================================

model Follow {
  id          String   @id @default(uuid())
  followerId  String
  followingId String
  status      String   @default("active") // active, pending (for private accounts)
  createdAt   DateTime @default(now())

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

// ============================================
// SOCIAL: POSTS & FEED
// ============================================

model Post {
  id         String   @id @default(uuid())
  userId     String
  type       String   @default("photo") // photo, video, text, carousel
  content    String?  // caption text
  media      String?  // JSON array of media URLs
  hashtags   String?  // JSON array
  mentions   String?  // JSON array of user IDs
  visibility String   @default("public") // public, followers, friends, private
  archived   Boolean  @default(false)
  likesCount Int      @default(0)
  commentsCount Int   @default(0)
  sharesCount Int     @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments  Comment[]
  likes     Like[]
  saves     Save[]
  bookmarks Bookmark[]

  @@index([userId])
  @@index([createdAt])
  @@index([visibility])
}

model Story {
  id        String   @id @default(uuid())
  userId    String
  type      String   @default("photo") // photo, video, poll, question
  media     String?
  content   String?
  stickers  String?  // JSON
  music     String?
  mentions  String?  // JSON
  pollData  String?  // JSON
  expiresAt DateTime
  viewCount Int      @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Comment {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  content   String
  parentId  String?  // for nested replies
  likesCount Int     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  post     Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies  Comment[] @relation("CommentReplies")

  @@index([postId])
  @@index([userId])
}

model Like {
  id        String   @id @default(uuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
}

model Save {
  id        String   @id @default(uuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model Bookmark {
  id         String   @id @default(uuid())
  userId     String
  postId     String
  collection String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

// ============================================
// MESSAGING
// ============================================

model Conversation {
  id          String   @id @default(uuid())
  type        String   @default("private") // private, group, channel, broadcast
  name        String?
  description String?
  avatar      String?
  createdById String?
  encrypted   Boolean  @default(false)
  lastMessageAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members  ConversationMember[]
  messages Message[]

  @@index([type])
  @@index([lastMessageAt])
}

model ConversationMember {
  id             String   @id @default(uuid())
  conversationId String
  userId         String
  role           String   @default("member") // admin, moderator, member
  muted          Boolean  @default(false)
  pinnedAt       DateTime?
  lastReadAt     DateTime?
  joinedAt       DateTime @default(now())
  leftAt         DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  senderId       String
  type           String   @default("text") // text, image, video, voice, file, sticker, gif, system
  content        String?
  media          String?  // JSON: url, type, size, duration
  encrypted      Boolean  @default(false)
  encryptedData  String?
  replyToId      String?
  forwarded      Boolean  @default(false)
  edited         Boolean  @default(false)
  pinned         Boolean  @default(false)
  selfDestruct   Int?     // seconds until self-destruct
  expiresAt      DateTime?
  readBy         String?  // JSON array of user IDs
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  replyTo      Message?     @relation("MessageReplies", fields: [replyToId], references: [id])
  replies      Message[]    @relation("MessageReplies")

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
}

// ============================================
// COMPANIO: COMPANION PROFILES & MATCHING
// ============================================

model CompanionProfile {
  id            String   @id @default(uuid())
  userId        String   @unique
  introduction  String?
  aboutMe       String?
  interests     String?  // JSON array
  hobbies       String?  // JSON array
  skills        String?  // JSON array
  languages     String?  // JSON array
  education     String?
  occupation    String?
  availability  String?  // JSON: schedule data
  timezone      String?
  city          String?
  country       String?
  ageRange      String?  // JSON: {min, max}
  active        Boolean  @default(true)
  
  // Marketplace fields
  hourlyRate    Float?
  currency      String   @default("USD")
  isVerifiedProvider Boolean @default(false)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  categories CompanionCategory[]
  preferences MatchPreference[]
  bookingsReceived Booking[]     @relation("CompanionBooked")
}

model CompanionCategory {
  id          String   @id @default(uuid())
  profileId   String
  category    String   // friend, study_partner, language_partner, gaming_partner, etc.
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  profile CompanionProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([category])
}

model MatchPreference {
  id        String   @id @default(uuid())
  profileId String
  key       String   // preferred_age_range, preferred_languages, preferred_timezone, etc.
  value     String   // JSON value
  createdAt DateTime @default(now())

  profile CompanionProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, key])
}

model Match {
  id            String   @id @default(uuid())
  user1Id       String
  user2Id       String
  score         Float    @default(0) // compatibility percentage 0-100
  explanation   String?  // JSON: reasons for match
  category      String?  // which companion category
  status        String   @default("suggested") // suggested, accepted, declined, expired
  user1Accepted Boolean  @default(false)
  user2Accepted Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user1 User @relation("MatchUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2 User @relation("MatchUser2", fields: [user2Id], references: [id], onDelete: Cascade)

  @@unique([user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
  @@index([status])
}

// ============================================
// COMMUNITIES
// ============================================

model Community {
  id          String   @id @default(uuid())
  name        String
  description String?
  avatar      String?
  coverImage  String?
  privacy     String   @default("public") // public, private, invite_only
  ownerId     String
  rules       String?  // JSON array of rules
  category    String?
  memberCount Int      @default(0)
  postCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  owner   User              @relation("CommunityOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members CommunityMember[]
  posts   CommunityPost[]
  events  Event[]

  @@index([ownerId])
  @@index([privacy])
  @@index([category])
}

model CommunityMember {
  id          String   @id @default(uuid())
  communityId String
  userId      String
  role        String   @default("member") // owner, admin, moderator, member
  joinedAt    DateTime @default(now())
  leftAt      DateTime?

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([communityId, userId])
  @@index([userId])
}

model CommunityPost {
  id          String   @id @default(uuid())
  communityId String
  authorId    String
  type        String   @default("discussion") // discussion, media, announcement, poll
  title       String?
  content     String
  media       String?  // JSON
  pinned      Boolean  @default(false)
  likesCount  Int      @default(0)
  repliesCount Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@index([communityId])
  @@index([createdAt])
}

// ============================================
// EVENTS & ACTIVITIES
// ============================================

model Event {
  id           String   @id @default(uuid())
  creatorId    String
  communityId  String?
  title        String
  description  String?
  type         String   // study_group, meetup, gaming, networking, travel, fitness, hobby, reading, volunteer
  location     String?
  isOnline     Boolean  @default(false)
  meetingLink  String?
  startTime    DateTime
  endTime      DateTime?
  recurring    String?  // JSON: recurrence rules
  maxAttendees Int?
  rsvpCount    Int      @default(0)
  status       String   @default("upcoming") // upcoming, ongoing, completed, cancelled
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  creator   User        @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  community Community?  @relation(fields: [communityId], references: [id])
  rsvps     EventRSVP[]

  @@index([creatorId])
  @@index([communityId])
  @@index([type])
  @@index([startTime])
}

model EventRSVP {
  id        String   @id @default(uuid())
  eventId   String
  userId    String
  status    String   @default("going") // going, interested, declined
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

// ============================================
// TRUST & SAFETY
// ============================================

model Report {
  id          String   @id @default(uuid())
  reporterId  String
  targetType  String   // user, post, comment, message, community
  targetId    String
  reason      String   // harassment, spam, scam, fake_profile, inappropriate, other
  description String?
  evidence    String?  // JSON: media URLs
  status      String   @default("pending") // pending, reviewing, resolved, dismissed
  resolution  String?
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime @default(now())

  reporter User @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  target   User @relation("ReportTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@index([reporterId])
  @@index([targetId])
  @@index([status])
}

model Block {
  id        String   @id @default(uuid())
  blockerId String
  blockedId String
  reason    String?
  createdAt DateTime @default(now())

  blocker User @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
}

model Verification {
  id         String   @id @default(uuid())
  userId     String
  type       String   // email, phone, government_id, video
  status     String   @default("pending") // pending, verified, rejected
  data       String?  // JSON: verification details
  verifiedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
}

model TrustScore {
  id               String   @id @default(uuid())
  userId           String   @unique
  overall          Float    @default(0)
  communication    Float    @default(0)
  reliability      Float    @default(0)
  activityScore    Float    @default(0)
  communityScore   Float    @default(0)
  totalReviews     Int      @default(0)
  totalRatings     Int      @default(0)
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Review {
  id           String   @id @default(uuid())
  reviewerId   String
  reviewedId   String
  category     String?  // companion category context
  rating       Float    // 1-5
  trustRating  Float?   // 1-5
  reliabilityRating Float? // 1-5
  communicationRating Float? // 1-5
  content      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  reviewer User @relation("Reviewer", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewed User @relation("Reviewed", fields: [reviewedId], references: [id], onDelete: Cascade)

  @@index([reviewedId])
}

// ============================================
// PRIVACY & SETTINGS
// ============================================

model PrivacySetting {
  id        String   @id @default(uuid())
  userId    String
  key       String   // profile_visibility, last_seen, online_status, phone_visibility, etc.
  value     String   // everyone, followers, friends, contacts, nobody, custom
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
}

model NotificationSetting {
  id        String   @id @default(uuid())
  userId    String
  key       String   // likes, comments, follows, messages, mentions, etc.
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String   // like, comment, follow, mention, message, match, event, system
  title     String?
  body      String
  data      String?  // JSON: additional data
  read      Boolean  @default(false)
  actionUrl String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}

model PushToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  platform  String   // web, android, ios
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============================================
// PHASE 11: MARKETPLACE, AI & WEBRTC
// ============================================

model Booking {
  id             String   @id @default(uuid())
  userId         String
  companionId    String
  startTime      DateTime
  endTime        DateTime
  status         String   @default("pending") // pending, confirmed, completed, cancelled, disputed
  totalPrice     Float?
  currency       String?
  paymentStatus  String   @default("unpaid") // unpaid, paid, refunded
  meetingLink    String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User             @relation("Booker", fields: [userId], references: [id], onDelete: Cascade)
  companion      CompanionProfile @relation("CompanionBooked", fields: [companionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([companionId])
  @@index([startTime])
}

// Friend request model
model FriendRequest {
  id          String   @id @default(uuid())
  requesterId String
  targetId    String
  location    String?   // e.g., city, country
  status      String   @default("pending") // pending, accepted, rejected
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  requester User @relation("FriendRequestsSent", fields: [requesterId], references: [id], onDelete: Cascade)
  target    User @relation("FriendRequestsReceived", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([requesterId, targetId])
  @@index([targetId, status])
}

// Family feature models
enum FamilyRole {
  PARENT
  CHILD
  GUARDIAN
}

model Family {
  id          String   @id @default(uuid())
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  members     FamilyMember[]
  users       User[]
}

model FamilyMember {
  id        String   @id @default(uuid())
  familyId  String
  userId    String
  role      FamilyRole @default(CHILD)
  joinedAt  DateTime @default(now())
  family    Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([familyId, userId])
  @@index([userId])
}


model AICompanion {
  id            String   @id @default(uuid())
  name          String
  avatar        String?
  shortDesc     String?
  personality   String?
  systemPrompt  String?
  voiceModel    String?
  category      String?
  isPremium     Boolean  @default(false)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  conversations AIConversation[]
}

model AIConversation {
  id            String   @id @default(uuid())
  userId        String
  aiCompanionId String
  summary       String?
  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  aiCompanion AICompanion @relation(fields: [aiCompanionId], references: [id], onDelete: Cascade)
  messages    AIMessage[]

  @@unique([userId, aiCompanionId])
  @@index([lastMessageAt])
}

model AIMessage {
  id             String   @id @default(uuid())
  conversationId String
  role           String   // user, assistant, system
  content        String
  audioUrl       String?
  createdAt      DateTime @default(now())

  conversation AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
}

model CallSession {
  id             String   @id @default(uuid())
  type           String   // audio, video
  status         String   @default("active") // active, ended
  isRandomMatch  Boolean  @default(false)
  startedAt      DateTime @default(now())
  endedAt        DateTime?

  participants   CallParticipant[]

  @@index([status])
}

model CallParticipant {
  id             String   @id @default(uuid())
  callId         String
  userId         String
  joinedAt       DateTime @default(now())
  leftAt         DateTime?
  duration       Int?

  call           CallSession @relation(fields: [callId], references: [id], onDelete: Cascade)
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([callId, userId])
  @@index([userId])
}
